{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Semantica",
  "version": "0.2.0",
  "identifier": "com.mysemantica.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Semantica",
        "url": "index.html",
        "width": 1100,
        "height": 720,
        "minWidth": 800,
        "minHeight": 580,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
